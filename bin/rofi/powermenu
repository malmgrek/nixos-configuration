#!/usr/bin/env sh

rofi_command='rofi'

### Options ###
hibernate="Hibernate"
lock="Lock"
logout="Logout"
power_off="Shutdown"
reboot="Reboot"
suspend="Sleep"
# Variable passed to rofi
OPTS="$power_off\n$reboot\n$lock\n$hibernate\n$suspend\n$logout"
LOCK=i3lock

case "$(echo -e "$OPTS" | $rofi_command -dmenu -selected-row 2)" in
    $power_off)
        systemctl poweroff
        ;;
    $hibernate)
        systemctl hibernate
        ;;
    $reboot)
        systemctl reboot
        ;;
    $lock)
        $LOCK
        ;;
    $suspend)
        $LOCK && systemctl suspend
        ;;
    $logout)
        i3-msg exit
        ;;
esac
